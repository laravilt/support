{
    "name": "@laravilt/support",
    "version": "1.0.0",
    "description": "Foundation package for Laravilt framework - Base Component class, Laravilt Core, and utilities",
    "type": "module",
    "main": "dist/laravilt-core.umd.js",
    "module": "dist/laravilt-core.es.js",
    "exports": {
        ".": {
            "import": "./dist/laravilt-core.es.js",
            "require": "./dist/laravilt-core.umd.js"
        },
        "./style.css": "./dist/laravilt-core.css"
    },
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "vite build --mode production"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "autoprefixer": "^10.4.16",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.4.0",
        "vite": "^5.0.0",
        "vue": "^3.4.0"
    },
    "peerDependencies": {
        "vue": "^3.4"
    }
}
